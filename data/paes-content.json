      "level": "foundation",
      "question": "¿Cuánto es 3/4 + 1/2?",
      "options": ["A) 1/2", "B) 5/4", "C) 4/6", "D) 2/3"],
      "answer": "B",
      "gap_if_wrong": "Fracciones básicas",
      "explanation": "Para sumar fracciones, necesitas el mínimo común múltiplo. 1/2 = 2/4, entonces 3/4 + 2/4 = 5/4"
